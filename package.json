{
  "name": "guitargpt",
  "version": "1.2.0",
  "description": "guitarGPT desktop client built with Electron and React.",
  "author": "Lahiru Sanjika (Cyber Security Researcher)",
  "main": "app/main/main.js",
  "scripts": {
    "build:renderer": "esbuild app/renderer/main.jsx --bundle --minify --legal-comments=none --outfile=app/renderer/bundle.js --platform=browser --format=esm --jsx=automatic --loader:.jsx=jsx && npm run obfuscate:renderer",
    "obfuscate:renderer": "node scripts/obfuscate-renderer.js",
    "start": "npm run build:renderer && electron .",
    "dist": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run build:renderer && electron-builder"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "esbuild": "^0.27.2",
    "javascript-obfuscator": "^5.1.0"
  },
  "overrides": {
    "tar": "^7.5.3"
  }
}
